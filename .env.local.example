DATABASE_URL=postgresql://postgres:postgres@localhost:5432/centient_dev

# Chain — pick one. Defaults to mainnet (42220).
# Mainnet:
NEXT_PUBLIC_CHAIN_ID=42220
CELO_RPC_URL=https://forno.celo.org
NEXT_PUBLIC_EXPLORER_URL=https://celoscan.io
# Testnet (Celo Sepolia):
# NEXT_PUBLIC_CHAIN_ID=11142220
# CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
# NEXT_PUBLIC_EXPLORER_URL=https://celo-sepolia.blockscout.com
#
# NOTE: the CELO_* / NEXT_PUBLIC_CHAIN_ID vars above are retained only while the
# Wave 2–5 consumers (lib/payout.ts, lib/celo-balance.ts, lib/admin-data.ts,
# lib/metamask.ts) are still on viem. They are removed once those migrate.

# ── Stellar chain config (ST-1a #291 — Wave 1 chain foundation) ──
# Network to target: "testnet" (default) or "public". Drives the Horizon URL,
# the transaction network passphrase, and the stellar.expert explorer base.
STELLAR_NETWORK=testnet
# Optional Horizon override (defaults: testnet https://horizon-testnet.stellar.org,
# public https://horizon.stellar.org).
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Platform hot-wallet secret (S… seed) the payout rail signs native-XLM payments
# with. Must be a funded account on the active network for real payouts. Generate
# a throwaway for local dev with: node -e "console.log(require('@stellar/stellar-sdk').Keypair.random().secret())"
STELLAR_PLATFORM_SECRET=S_your_funded_platform_account_secret
# NEXT_PUBLIC_EXPLORER_URL (declared above) also overrides the Stellar explorer
# base; leave it unset to default to stellar.expert for the active network.

# Server hot wallet — must be funded with the reward token + native CELO for gas.
# Must be a valid 32-byte hex private key (0x + 64 hex chars). For local dev you
# can use a throwaway/unfunded key just to boot the app — generate one with:
#   echo "0x$(openssl rand -hex 32)"
# Real payouts need this funded; an invalid value is tolerated (wallet health
# reports "not configured") but on-chain payouts will fail.
PAYOUT_PRIVATE_KEY=0x_your_funded_hot_wallet_private_key

# Reward token — defaults to mainnet cUSD (18 decimals). Override per chain.
# Mainnet cUSD:
REWARD_TOKEN_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
NEXT_PUBLIC_REWARD_TOKEN_SYMBOL=cUSD
NEXT_PUBLIC_REWARD_TOKEN_DECIMALS=18
NEXT_PUBLIC_REWARD_AMOUNT=0.05
# Sepolia USDC (6 decimals):
# REWARD_TOKEN_ADDRESS=0x01c5c0122039549ad1493b8220cabedd739bc44e
# NEXT_PUBLIC_REWARD_TOKEN_SYMBOL=USDC
# NEXT_PUBLIC_REWARD_TOKEN_DECIMALS=6
# NEXT_PUBLIC_REWARD_AMOUNT=0.01

# Admin dashboard (/admin) — required for the operator tool at /admin.
# ADMIN_JWT_SECRET must be ≥ 32 chars. Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=change_me_to_a_random_64_char_hex_string_from_openssl_rand
# Optional override for the seeded default admin password.
# Re-seeding after the row exists leaves the password untouched, so rotating
# after first deploy requires either updating admin_users.password_hash directly
# or removing the row and re-seeding with ADMIN_SEED_PASSWORD set.
# ADMIN_SEED_PASSWORD=GoCent!123
RESEND_API_KEY=get_api_key_from_resend_com
NEXT_PUBLIC_APP_URL=your_local_host_url
RESEND_EMAIL_FROM=email_placeholder

# Gold task serving ratio — fraction of tasks served as platform gold checks.
# Must be between 0 and 1. Defaults to 0.1 (10% gold).
# GOLD_TASK_RATIO=0.1

# Reason repetition detection — flags identical/near-identical submission reasons.
# REASON_REPEAT_WINDOW=10   (default 10) — number of recent reasons to compare against
# REASON_REPEAT_MAX=3       (default 3)  — exact duplicate threshold; submitting the same
#                                         reason >= MAX times within the window is blocked

# Internal Centient customer account — used for dogfooding.
# Set this to seed the customer account in non-production environments.
# INTERNAL_CUSTOMER_PASSWORD=GoCent!123

# Sentry — error tracking for client and server.
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Wallet balance thresholds — Discord alerting + /api/health/wallet use these.
# Defaults (if unset):
BALANCE_WARN_CELO=0.5
BALANCE_PAGE_CELO=0.1
BALANCE_WARN_REWARD=50
BALANCE_PAGE_REWARD=10

# Discord webhook for wallet balance alerts (optional — no-op if unset).
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# PostHog — product analytics.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
ANALYTICS_HMAC_SECRET=change_me_for_webhook_verification

# Hot-wallet per-day spend cap (application-layer). Defaults to ~$200 in cUSD.
# Set to 0 to disable the cap.
# DAILY_PAYOUT_CAP_WEI=200000000000000000000

# Redis URL for persistent alert cooldown state (Railway provides REDIS_URL automatically).
# Only needed if DISCORD_WEBHOOK_URL is also set.
# REDIS_URL=redis://localhost:6379

# Discord webhook URL for cap threshold alerts (80% consumed).
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Cron endpoint authentication — shared secret between the platform scheduler
# (cron-job.org, Railway cron, Vercel CRON, etc.) and the /api/cron/* endpoints.
# Generate with: openssl rand -hex 32
# CRON_SECRET=change_me_to_a_random_64_char_hex_string_from_openssl_rand

# Platform fee deducted from campaign balance per submission (in wei, 18 decimals).
# Required when campaign balance is enabled. $0.15 cUSD = 150000000000000000
PLATFORM_FEE_WEI=150000000000000000

# Minimum accumulated balance a labeler must reach before withdrawing (in wei,
# 18 decimals), so each on-chain payout stays gas-economical. Required and
# fail-fast: the withdrawal endpoint errors if this is unset/invalid. 1 cUSD = 1000000000000000000
MIN_WITHDRAWAL_WEI=1000000000000000000

# Withdrawal eligibility gates (P4a, anti-fraud) — quality history required to
# cash out, so mass-created wallet-less accounts can't instantly withdraw. Each
# gate is opt-in: unset or 0 disables it. Recommended production values shown.
# WITHDRAWAL_MIN_SUBMISSIONS=50
# WITHDRAWAL_MIN_GOLD_RATE=0.7
# WITHDRAWAL_MIN_ACCOUNT_AGE_HOURS=24

# ── Local MiniPay simulation (dev only; hard-off when NODE_ENV=production) ──
# Set to 1 to simulate running inside MiniPay end-to-end (login + payout) with
# no MetaMask, no MiniPay account, and no Celo connection. Run `pnpm payout`
# alongside `pnpm dev` so the queued payout job is processed.
# NEXT_PUBLIC_SIMULATE_MINIPAY=1
# Optional: override the simulated labeler's local test key (throwaway, no funds).
# NEXT_PUBLIC_SIMULATED_WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
#
# When this flag is on, the app opens to a Login screen with a "Login with
# MiniPay" button (uses the simulated key) and an extra dev-only
# "Simulate MiniPay login" button.
