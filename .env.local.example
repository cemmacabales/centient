DATABASE_URL=postgresql://postgres:postgres@localhost:5432/centient_dev

# Chain — pick one. Defaults to mainnet (42220).
# Mainnet:
NEXT_PUBLIC_CHAIN_ID=42220
CELO_RPC_URL=https://forno.celo.org
NEXT_PUBLIC_EXPLORER_URL=https://celoscan.io
# Testnet (Celo Sepolia):
# NEXT_PUBLIC_CHAIN_ID=11142220
# CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
# NEXT_PUBLIC_EXPLORER_URL=https://celo-sepolia.blockscout.com

# Server hot wallet — must be funded with the reward token + native CELO for gas.
PAYOUT_PRIVATE_KEY=0x_your_funded_hot_wallet_private_key

# Reward token — defaults to mainnet cUSD (18 decimals). Override per chain.
# Mainnet cUSD:
REWARD_TOKEN_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
NEXT_PUBLIC_REWARD_TOKEN_SYMBOL=cUSD
NEXT_PUBLIC_REWARD_TOKEN_DECIMALS=18
NEXT_PUBLIC_REWARD_AMOUNT=0.05
# Sepolia USDC (6 decimals):
# REWARD_TOKEN_ADDRESS=0x01c5c0122039549ad1493b8220cabedd739bc44e
# NEXT_PUBLIC_REWARD_TOKEN_SYMBOL=USDC
# NEXT_PUBLIC_REWARD_TOKEN_DECIMALS=6
# NEXT_PUBLIC_REWARD_AMOUNT=0.01

# Admin dashboard (/admin) — required for the operator tool at /admin.
# ADMIN_SESSION_PASSWORD must be ≥ 32 chars. Generate with: openssl rand -hex 32
ADMIN_SESSION_PASSWORD=change_me_to_a_random_64_char_hex_string_from_openssl_rand
# Optional override for the seeded default admin password.
# Re-seeding after the row exists leaves the password untouched, so rotating
# after first deploy requires either updating admin_users.password_hash directly
# or removing the row and re-seeding with ADMIN_SEED_PASSWORD set.
# ADMIN_SEED_PASSWORD=GoCent!123
