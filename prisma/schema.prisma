generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: url lives in prisma.config.ts, NOT here.
}

model User {
  walletAddress        String   @id
  createdAt            DateTime @default(now())
  totalEarnedWei       BigInt   @default(0)
  submissionCount      Int      @default(0)
  goldCorrect          Int      @default(0)
  goldAttempted        Int      @default(0)
  isBanned             Boolean  @default(false)
  bannedAt             DateTime?
  bannedReason         String?
  banCount             Int      @default(0)
  bannedUntil          DateTime?
  lastBanAt            DateTime?
  country              String?
  gender               String?
  ageRange             String?
  onboardingCompleted  Boolean  @default(false)
  lastSubmissionAt     DateTime?

  submissions Submission[]

  @@map("users")
}

model AdminUser {
  id                          String    @id @default(uuid())
  email                       String    @unique
  passwordHash                String
  role                        AdminRole
  companyName                 String?
  createdAt                   DateTime  @default(now())
  isVerified                  Boolean   @default(false)
  verificationToken           String?   @unique
  verificationTokenExpires    DateTime?
  verifiedAt                  DateTime?

  campaigns Campaign[]
  auditLogs AdminAuditLog[]
  uploadJobs UploadJob[]

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  CUSTOMER
}

model Campaign {
  id                    String   @id @default(uuid())
  adminUserId           String
  name                  String
  defaultResponseTarget Int
  rewardWei             BigInt
  csvFileName           String?
  pausedAt              DateTime?
  createdAt             DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  tasks     Task[]
  uploadJobs UploadJob[]

  @@index([adminUserId])
  @@map("campaigns")
}

model Task {
  id             String   @id @default(uuid())
  prompt         String
  responseA      String
  responseB      String
  modelA         String?
  modelB         String?
  category       String?
  isGold         Boolean  @default(false)
  goldAnswer     String?
  createdAt      DateTime @default(now())
  campaignId     String?
  responseTarget Int?
  rewardWei      BigInt?

  submissions Submission[]
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, prompt])
  @@index([isGold])
  @@index([campaignId])
  @@index([isGold, createdAt])
  @@map("tasks")
}

model Submission {
  id              String   @id @default(uuid())
  walletAddress   String
  taskId          String
  choice          String
  reason          String
  isGoldCheck     Boolean  @default(false)
  goldPassed      Boolean?
  payoutAmountWei BigInt
  payoutTxHash    String?
  payoutStatus    String   @default("pending")
  createdAt       DateTime @default(now())

  user User @relation(fields: [walletAddress], references: [walletAddress])
  task Task @relation(fields: [taskId], references: [id])

  @@unique([walletAddress, taskId])
  @@index([walletAddress])
  @@index([payoutStatus])
  @@index([payoutStatus, createdAt])
  @@index([taskId])
  @@map("submissions")
}

model WalletNonce {
  id            String    @id @default(uuid())
  walletAddress String
  nonce         String    @unique
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([walletAddress])
  @@index([expiresAt])
  @@map("wallet_nonces")
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminUserId  String
  action       String   // "campaign.create", "campaign.update", "campaign.delete", "customer.create", "customer.delete", "tasks.upload", "tasks.upload.queued", "tasks.upload.completed", "tasks.upload.failed", "tasks.upload.retry", "export.download"
  targetType   String   // "campaign", "adminUser", "submission"
  targetId     String?  // nullable for bulk actions like "tasks.upload"
  metadata     Json?    // shape depends on action; capture diff for updates, count for bulk
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_log")
}

enum UploadJobStatus {
  queued
  processing
  done
  failed
  cancelled
}

model UploadJob {
  id                String           @id @default(uuid())
  campaignId        String
  adminUserId       String
  fileName          String
  fileSize          Int
  status            UploadJobStatus  @default(queued)
  totalRows         Int
  processedRows     Int              @default(0)
  upsertedRows      Int              @default(0)
  skippedRows       Int              @default(0)
  errorRows         Int              @default(0)
  chunksCommitted   Int              @default(0)
  chunksTotal       Int              @default(0)
  errorSamples      Json?
  lastError         String?
  rawText           String
  workerHeartbeatAt DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([status, createdAt])
  @@index([campaignId, createdAt])
  @@index([status, workerHeartbeatAt])
  @@map("upload_jobs")
}
