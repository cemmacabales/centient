generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  // NOTE: url lives in prisma.config.ts, NOT here.
}

model User {
  id                   String   @id @default(uuid())
  walletAddress        String?  @unique
  email                String?  @unique
  passwordHash         String?
  isVerified           Boolean  @default(false)
  verificationToken    String?  @unique
  verificationTokenExpires DateTime?
  verifiedAt           DateTime?
  createdAt            DateTime @default(now())
  totalEarnedStroops       BigInt   @default(0)
  pendingBalanceStroops    BigInt   @default(0)
  submissionCount      Int      @default(0)
  goldCorrect          Int      @default(0)
  goldAttempted        Int      @default(0)
  isBanned             Boolean  @default(false)
  bannedAt             DateTime?
  bannedReason         String?
  banCount             Int      @default(0)
  bannedUntil          DateTime?
  lastBanAt            DateTime?
  country              String?
  gender               String?
  ageRange             String?
  onboardingCompleted  Boolean  @default(false)
  lastSubmissionAt     DateTime?

  submissions   Submission[]
  disputes      Dispute[]
  balanceLedger UserBalanceLedger[]
  payoutJobs    PayoutJob[]
  identifierHistory UserIdentifierHistory[]
  flaggedWithdrawals FlaggedWithdrawal[]

  @@map("users")
}

enum BannedIdentifierType {
  EMAIL
  WALLET
  USER_ID
}

model BannedIdentity {
  id             String             @id @default(uuid())
  identifierType BannedIdentifierType
  identifierValue String
  bannedAt       DateTime           @default(now())
  bannedUntil    DateTime?
  reason         String?

  @@unique([identifierType, identifierValue])
  @@index([identifierType, identifierValue])
  @@map("banned_identities")
}

enum IdentifierType {
  EMAIL
  WALLET
}

model UserIdentifierHistory {
  id           String        @id @default(uuid())
  userId       String
  identifierType IdentifierType
  identifierValue String
  linkedAt     DateTime      @default(now())
  unlinkedAt   DateTime?
  isActive     Boolean       @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([identifierType, identifierValue])
  @@index([userId, isActive])
  @@map("user_identifier_history")
}

model AdminUser {
  id                          String    @id @default(uuid())
  email                       String    @unique
  passwordHash                String
  role                        AdminRole
  companyName                 String?
  createdAt                   DateTime  @default(now())
  isVerified                  Boolean   @default(false)
  verificationToken           String?   @unique
  verificationTokenExpires    DateTime?
  verifiedAt                  DateTime?

  campaigns Campaign[]
  auditLogs AdminAuditLog[]
  uploadJobs UploadJob[]

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  CUSTOMER
}

model Campaign {
  id                    String   @id @default(uuid())
  adminUserId           String
  name                  String
  defaultResponseTarget Int
  rewardStroops             BigInt
  csvFileName           String?
  pausedAt              DateTime?
  createdAt             DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  tasks     Task[]
  uploadJobs UploadJob[]
  balance    CampaignBalance?
  balanceLedger BalanceLedger[]

  @@index([adminUserId])
  @@map("campaigns")
}

model Task {
  id             String   @id @default(uuid())
  prompt         String
  responseA      String
  responseB      String
  modelA         String?
  modelB         String?
  category       String?
  isGold         Boolean  @default(false)
  goldAnswer     String?
  createdAt      DateTime @default(now())
  campaignId     String?
  responseTarget Int?
  rewardStroops      BigInt?
  majorityAnswer String?
  agreementScore Float?
  resolvedAt     DateTime?
  disabled       Boolean   @default(false)

  submissions Submission[]
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, prompt])
  @@index([isGold])
  @@index([campaignId])
  @@index([isGold, createdAt])
  @@map("tasks")
}

model Submission {
  id              String    @id @default(uuid())
  walletAddress   String
  userId          String
  taskId          String
  choice          String
  reason          String
  isGoldCheck     Boolean   @default(false)
  goldPassed      Boolean?
  payoutAmountStroops BigInt
  payoutTxHash    String?
  payoutStatus    String    @default("pending")
  retryCount      Int       @default(0)
  payoutError     String?
  lastRetriedAt   DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
  task Task @relation(fields: [taskId], references: [id])
  payoutJob PayoutJob?

  @@unique([walletAddress, taskId])
  @@unique([userId, taskId])
  @@index([walletAddress])
  @@index([userId])
  @@index([payoutStatus])
  @@index([payoutStatus, createdAt])
  @@index([payoutStatus, retryCount])
  @@index([lastRetriedAt])
  @@index([taskId])
  @@map("submissions")
}

model Dispute {
  id            String   @id @default(uuid())
  walletAddress String   // no FK to User — intentional for forensic/compliance retention if user is deleted
  userId        String?
  reason        String
  status        String   @default("open") // "open" | "resolved"
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([walletAddress])
  @@index([status, createdAt])
  @@map("disputes")
}

model WalletNonce {
  id            String    @id @default(uuid())
  walletAddress String
  nonce         String    @unique
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([walletAddress])
  @@index([expiresAt])
  @@map("wallet_nonces")
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminUserId  String
  action       String   // "campaign.create", "campaign.update", "campaign.delete", "customer.create", "customer.delete", "tasks.upload", "tasks.upload.queued", "tasks.upload.completed", "tasks.upload.failed", "tasks.upload.retry", "export.download"
  targetType   String   // "campaign", "adminUser", "submission"
  targetId     String?  // nullable for bulk actions like "tasks.upload"
  metadata     Json?    // shape depends on action; capture diff for updates, count for bulk
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_log")
}

enum UploadJobStatus {
  queued
  processing
  done
  failed
  cancelled
}

enum PayoutJobStatus {
  queued
  processing
  done
  failed
}

enum PayoutJobType {
  SUBMISSION_PAYOUT
  WITHDRAWAL
}

model PayoutJob {
  id                 String          @id @default(uuid())
  type               PayoutJobType   @default(SUBMISSION_PAYOUT)
  // Per-submission payouts reference a submission; lump-sum withdrawals do not.
  submissionId       String?         @unique
  // Lump-sum withdrawals reference the user + snapshot the amount and destination
  // at request time. Null for per-submission payouts (derived from the submission).
  userId             String?
  amountStroops          BigInt?
  destinationAddress String?
  txHash             String?
  status             PayoutJobStatus @default(queued)
  workerHeartbeatAt  DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  lastError          String?
  retryCount         Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  submission Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([status, workerHeartbeatAt])
  @@index([userId])
  @@unique([userId], name: "payout_jobs_user_inflight_withdrawal_key", map: "payout_jobs_user_inflight_withdrawal_key", where: raw("\"type\" = 'WITHDRAWAL' AND \"status\" IN ('queued', 'processing')"))
  @@map("payout_jobs")
}

model UploadJob {
  id                String           @id @default(uuid())
  campaignId        String
  adminUserId       String
  fileName          String
  fileSize          Int
  status            UploadJobStatus  @default(queued)
  totalRows         Int
  processedRows     Int              @default(0)
  upsertedRows      Int              @default(0)
  skippedRows       Int              @default(0)
  errorRows         Int              @default(0)
  chunksCommitted   Int              @default(0)
  chunksTotal       Int              @default(0)
  errorSamples      Json?
  lastError         String?
  rawText           String
  workerHeartbeatAt DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([status, createdAt])
  @@index([campaignId, createdAt])
  @@index([status, workerHeartbeatAt])
  @@map("upload_jobs")
}

enum LedgerType {
  DEPOSIT
  DEBIT_REWARD
  DEBIT_FEE
  REFUND
}

model CampaignBalance {
  id         String   @id @default(uuid())
  campaignId String   @unique
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  balanceStroops BigInt   @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("campaign_balances")
}

model BalanceLedger {
  id           String     @id @default(uuid())
  campaignId   String
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type         LedgerType
  amountStroops    BigInt
  submissionId String?    // no FK — intentional: ledger entries survive submission lifecycle changes
  note         String?
  createdAt    DateTime   @default(now())

  @@index([campaignId, createdAt])
  @@map("balance_ledger")
}

enum UserLedgerType {
  CREDIT_REWARD
  WITHDRAWAL
  REVERSAL
}

// Off-chain labeler balance ledger — mirrors BalanceLedger. Approved answers credit
// pendingBalanceStroops (CREDIT_REWARD); withdrawals debit it (WITHDRAWAL); failed/reversed
// withdrawals re-credit (REVERSAL). Schema only in P0a — no writes yet.
model UserBalanceLedger {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         UserLedgerType
  amountStroops    BigInt
  submissionId String?        // no FK — intentional: ledger entries survive submission lifecycle changes
  note         String?
  createdAt    DateTime       @default(now())

  @@index([userId, createdAt])
  @@map("user_balance_ledger")
}

// Why a withdrawal was blocked by the P4a/P4b anti-fraud gates. Severity orders the
// admin review queue (P4c): a banned identity is more urgent than a quality gate.
enum FlaggedWithdrawalReason {
  BANNED_IDENTITY  // an email/wallet/userId on the account is on the ban list — CRITICAL
  SHARED_WALLET    // the destination wallet is cashing out for too many accounts — HIGH
  INELIGIBLE       // failed a quality/age/min-submission eligibility gate — LOW
}

enum FlaggedWithdrawalStatus {
  PENDING   // awaiting admin review
  APPROVED  // admin cleared the flag; the labeler may retry the withdrawal
  REJECTED  // admin dismissed the attempt (optionally with a ban)
}

// P4c — every withdrawal blocked by an anti-fraud gate is recorded here so admins
// have a review queue with the trigger reason. The withdraw endpoint still rejects
// the attempt synchronously; this row is the audit/review artifact. Resolutions are
// also written to AdminAuditLog. One PENDING row per (userId, reason) — repeated
// blocked attempts refresh the existing row rather than spamming the queue.
model FlaggedWithdrawal {
  id               String                  @id @default(uuid())
  userId           String
  walletAddress    String?
  reason           FlaggedWithdrawalReason
  detail           Json?                   // trigger context: accountCount, identifierType, gate reason, required/actual
  balanceStroops       BigInt                  @default(0) // pending balance snapshot at flag time
  status           FlaggedWithdrawalStatus @default(PENDING)
  resolvedByAdminId String?
  resolvedAt       DateTime?
  resolutionNote   String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId])
  @@unique([userId, reason], name: "flagged_withdrawals_userId_reason_pending_uniq", map: "flagged_withdrawals_userId_reason_pending_uniq", where: { status: "PENDING" })
  @@map("flagged_withdrawals")
}
