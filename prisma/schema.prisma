generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: url lives in prisma.config.ts, NOT here.
}

model User {
  id                   String   @id @default(uuid())
  walletAddress        String?  @unique
  email                String?  @unique
  passwordHash         String?
  isVerified           Boolean  @default(false)
  verificationToken    String?  @unique
  verificationTokenExpires DateTime?
  verifiedAt           DateTime?
  createdAt            DateTime @default(now())
  totalEarnedWei       BigInt   @default(0)
  pendingBalanceWei    BigInt   @default(0)
  submissionCount      Int      @default(0)
  goldCorrect          Int      @default(0)
  goldAttempted        Int      @default(0)
  isBanned             Boolean  @default(false)
  bannedAt             DateTime?
  bannedReason         String?
  banCount             Int      @default(0)
  bannedUntil          DateTime?
  lastBanAt            DateTime?
  country              String?
  gender               String?
  ageRange             String?
  onboardingCompleted  Boolean  @default(false)
  lastSubmissionAt     DateTime?

  submissions   Submission[]
  disputes      Dispute[]
  balanceLedger UserBalanceLedger[]

  @@map("users")
}

model AdminUser {
  id                          String    @id @default(uuid())
  email                       String    @unique
  passwordHash                String
  role                        AdminRole
  companyName                 String?
  createdAt                   DateTime  @default(now())
  isVerified                  Boolean   @default(false)
  verificationToken           String?   @unique
  verificationTokenExpires    DateTime?
  verifiedAt                  DateTime?

  campaigns Campaign[]
  auditLogs AdminAuditLog[]
  uploadJobs UploadJob[]

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  CUSTOMER
}

model Campaign {
  id                    String   @id @default(uuid())
  adminUserId           String
  name                  String
  defaultResponseTarget Int
  rewardWei             BigInt
  csvFileName           String?
  pausedAt              DateTime?
  createdAt             DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  tasks     Task[]
  uploadJobs UploadJob[]
  balance    CampaignBalance?
  balanceLedger BalanceLedger[]

  @@index([adminUserId])
  @@map("campaigns")
}

model Task {
  id             String   @id @default(uuid())
  prompt         String
  responseA      String
  responseB      String
  modelA         String?
  modelB         String?
  category       String?
  isGold         Boolean  @default(false)
  goldAnswer     String?
  createdAt      DateTime @default(now())
  campaignId     String?
  responseTarget Int?
  rewardWei      BigInt?
  majorityAnswer String?
  agreementScore Float?
  resolvedAt     DateTime?
  disabled       Boolean   @default(false)

  submissions Submission[]
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, prompt])
  @@index([isGold])
  @@index([campaignId])
  @@index([isGold, createdAt])
  @@map("tasks")
}

model Submission {
  id              String    @id @default(uuid())
  walletAddress   String
  userId          String
  taskId          String
  choice          String
  reason          String
  isGoldCheck     Boolean   @default(false)
  goldPassed      Boolean?
  payoutAmountWei BigInt
  payoutTxHash    String?
  payoutStatus    String    @default("pending")
  retryCount      Int       @default(0)
  payoutError     String?
  lastRetriedAt   DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
  task Task @relation(fields: [taskId], references: [id])
  payoutJob PayoutJob?

  @@unique([walletAddress, taskId])
  @@unique([userId, taskId])
  @@index([walletAddress])
  @@index([userId])
  @@index([payoutStatus])
  @@index([payoutStatus, createdAt])
  @@index([payoutStatus, retryCount])
  @@index([lastRetriedAt])
  @@index([taskId])
  @@map("submissions")
}

model Dispute {
  id            String   @id @default(uuid())
  walletAddress String   // no FK to User — intentional for forensic/compliance retention if user is deleted
  userId        String?
  reason        String
  status        String   @default("open") // "open" | "resolved"
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([walletAddress])
  @@index([status, createdAt])
  @@map("disputes")
}

model WalletNonce {
  id            String    @id @default(uuid())
  walletAddress String
  nonce         String    @unique
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([walletAddress])
  @@index([expiresAt])
  @@map("wallet_nonces")
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminUserId  String
  action       String   // "campaign.create", "campaign.update", "campaign.delete", "customer.create", "customer.delete", "tasks.upload", "tasks.upload.queued", "tasks.upload.completed", "tasks.upload.failed", "tasks.upload.retry", "export.download"
  targetType   String   // "campaign", "adminUser", "submission"
  targetId     String?  // nullable for bulk actions like "tasks.upload"
  metadata     Json?    // shape depends on action; capture diff for updates, count for bulk
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_log")
}

enum UploadJobStatus {
  queued
  processing
  done
  failed
  cancelled
}

enum PayoutJobStatus {
  queued
  processing
  done
  failed
}

model PayoutJob {
  id                String         @id @default(uuid())
  submissionId      String         @unique
  status            PayoutJobStatus @default(queued)
  workerHeartbeatAt DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  lastError         String?
  retryCount        Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([status, workerHeartbeatAt])
  @@map("payout_jobs")
}

model UploadJob {
  id                String           @id @default(uuid())
  campaignId        String
  adminUserId       String
  fileName          String
  fileSize          Int
  status            UploadJobStatus  @default(queued)
  totalRows         Int
  processedRows     Int              @default(0)
  upsertedRows      Int              @default(0)
  skippedRows       Int              @default(0)
  errorRows         Int              @default(0)
  chunksCommitted   Int              @default(0)
  chunksTotal       Int              @default(0)
  errorSamples      Json?
  lastError         String?
  rawText           String
  workerHeartbeatAt DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([status, createdAt])
  @@index([campaignId, createdAt])
  @@index([status, workerHeartbeatAt])
  @@map("upload_jobs")
}

enum LedgerType {
  DEPOSIT
  DEBIT_REWARD
  DEBIT_FEE
  REFUND
}

model CampaignBalance {
  id         String   @id @default(uuid())
  campaignId String   @unique
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  balanceWei BigInt   @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("campaign_balances")
}

model BalanceLedger {
  id           String     @id @default(uuid())
  campaignId   String
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type         LedgerType
  amountWei    BigInt
  submissionId String?    // no FK — intentional: ledger entries survive submission lifecycle changes
  note         String?
  createdAt    DateTime   @default(now())

  @@index([campaignId, createdAt])
  @@map("balance_ledger")
}

enum UserLedgerType {
  CREDIT_REWARD
  WITHDRAWAL
  REVERSAL
}

// Off-chain labeler balance ledger — mirrors BalanceLedger. Approved answers credit
// pendingBalanceWei (CREDIT_REWARD); withdrawals debit it (WITHDRAWAL); failed/reversed
// withdrawals re-credit (REVERSAL). Schema only in P0a — no writes yet.
model UserBalanceLedger {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         UserLedgerType
  amountWei    BigInt
  submissionId String?        // no FK — intentional: ledger entries survive submission lifecycle changes
  note         String?
  createdAt    DateTime       @default(now())

  @@index([userId, createdAt])
  @@map("user_balance_ledger")
}
