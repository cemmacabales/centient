generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: url lives in prisma.config.ts, NOT here.
}

model User {
  walletAddress        String   @id
  createdAt            DateTime @default(now())
  totalEarnedWei       BigInt   @default(0)
  submissionCount      Int      @default(0)
  goldCorrect          Int      @default(0)
  goldAttempted        Int      @default(0)
  isBanned             Boolean  @default(false)
  country              String?
  gender               String?
  ageRange             String?
  onboardingCompleted  Boolean  @default(false)

  submissions Submission[]

  @@map("users")
}

model AdminUser {
  id                          String    @id @default(uuid())
  email                       String    @unique
  passwordHash                String
  role                        AdminRole
  companyName                 String?
  createdAt                   DateTime  @default(now())
  isVerified                  Boolean   @default(false)
  verificationToken           String?   @unique
  verificationTokenExpires    DateTime?
  verifiedAt                  DateTime?

  campaigns Campaign[]
  auditLogs AdminAuditLog[]

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  CUSTOMER
}

model Campaign {
  id                    String   @id @default(uuid())
  adminUserId           String
  name                  String
  defaultResponseTarget Int
  csvFileName           String?
  createdAt             DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  tasks     Task[]

  @@index([adminUserId])
  @@map("campaigns")
}

model Task {
  id             String   @id @default(uuid())
  prompt         String
  responseA      String
  responseB      String
  modelA         String?
  modelB         String?
  category       String?
  isGold         Boolean  @default(false)
  goldAnswer     String?
  createdAt      DateTime @default(now())
  campaignId     String?
  responseTarget Int?

  submissions Submission[]
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, prompt])
  @@index([isGold])
  @@index([campaignId])
  @@map("tasks")
}

model Submission {
  id              String   @id @default(uuid())
  walletAddress   String
  taskId          String
  choice          String
  reason          String
  isGoldCheck     Boolean  @default(false)
  goldPassed      Boolean?
  payoutAmountWei BigInt
  payoutTxHash    String?
  payoutStatus    String   @default("pending")
  createdAt       DateTime @default(now())

  user User @relation(fields: [walletAddress], references: [walletAddress])
  task Task @relation(fields: [taskId], references: [id])

  @@unique([walletAddress, taskId])
  @@index([walletAddress])
  @@index([payoutStatus])
  @@map("submissions")
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminUserId  String
  action       String   // "campaign.create", "campaign.update", "campaign.delete", "customer.create", "customer.delete", "tasks.upload", "export.download"
  targetType   String   // "campaign", "adminUser", "submission"
  targetId     String?  // nullable for bulk actions like "tasks.upload"
  metadata     Json?    // shape depends on action; capture diff for updates, count for bulk
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_log")
}
